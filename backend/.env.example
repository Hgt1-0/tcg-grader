# CardProof Backend — Environment Variables
# Copy this file to .env and fill in your keys

# ── Groq AI (Card Grading) ────────────────────────────────────────────────────
# Get your key at: https://console.groq.com
# Used for: AI-powered PSA card grading via vision model
GROQ_API_KEY=your_groq_api_key_here

# ── Crossmint (NFT Minting) ───────────────────────────────────────────────────
# Get your key at: https://staging.crossmint.com/console → API Keys
# Used for: Minting graded cards as NFTs on Solana devnet (email or wallet delivery)
CROSSMINT_API_KEY=sk_staging_your_crossmint_api_key_here

# Create a collection at: https://staging.crossmint.com/console → Collections
# Chain: Solana | Environment: Staging
CROSSMINT_COLLECTION_ID=your_collection_id_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
